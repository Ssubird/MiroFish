# LLM provider
# This is the upstream OpenAI-compatible inference endpoint.
# The backend uses this base URL for:
# - GET  {LLM_BASE_URL}/models
# - POST {LLM_BASE_URL}/chat/completions
# World Studio "读取模型" and "测试模型" go through this address family.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# Optional Flask dev-server reload switch.
# Default is false in backend/run.py because Werkzeug auto-reload can leave
# a stale port-5001 process on Windows that stops answering /api/lottery/*.
# FLASK_USE_RELOADER=false

# Optional remote graph
ZEP_API_KEY=your_zep_api_key_here

# Optional boosted LLM
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# Lottery workspace
# LOTTERY_DATA_ROOT=./ziweidoushu
# LOTTERY_WORLD_STATE_ROOT=./ziweidoushu/.world_state
# LOTTERY_RUNTIME_MODE=legacy

# Optional local kuzu graph
# KUZU_GRAPH_ROOT=./ziweidoushu/.kuzu_graph

# Optional local Letta server
# This is NOT the model provider endpoint.
# It is used only for Letta agent, memory, and MCP orchestration.
# Do not point model-list or chat-completion requests here.
# LETTA_BASE_URL=http://127.0.0.1:8283/v1
# LETTA_SERVER_API_KEY=
# LETTA_API_KEY=your_embedding_provider_api_key_here
# LETTA_EMBEDDING_MODEL=openai/text-embedding-3-small
# MCP_DISABLE_STDIO=false
# LOTTERY_WORLD_ALLOW_NO_MCP=false
